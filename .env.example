# FARRUKH CONSULTANCY — IMMIGRATION CRM
# Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file to .env  (never commit .env to GitHub)
#   2. Fill in your Firebase project values below
#   3. In Vercel: Settings → Environment Variables → add each key
# ═══════════════════════════════════════════════════════════════════

# ── Firebase Config ──────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ── Notes ────────────────────────────────────────────────────────
# All variables MUST start with VITE_ to be exposed in the browser
# Never put secret API keys here — Firebase web config is public-facing
# Firebase security is enforced through Firestore/Storage Rules
